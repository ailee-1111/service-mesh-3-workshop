#!/bin/bash
# ==============================================================================
# Red Hat OpenShift Service Mesh 3.0 Workshop - Custom lab 에뮬레이션 스크립트
# ==============================================================================
set -eo pipefail

COMMAND="$1"
LAB_NAME="$2"

if [ -z "$COMMAND" ] || [ -z "$LAB_NAME" ]; then
    echo "Usage: lab [start|finish] [lab-name]"
    exit 1
fi

if [ "$LAB_NAME" != "meshintro-bookinfo" ]; then
    echo "❌ Error: Lab '$LAB_NAME'은 현재 환경에서 지원되지 않는 랩 코드입니다."
    exit 1
fi

# 1. 환경 변수로부터 JUPYTERHUB_USER 감지 (user1~5)
USER_NAME="${JUPYTERHUB_USER:-user}"
NAMESPACE="${USER_NAME}-meshintro-bookinfo"

if [ "$COMMAND" = "start" ]; then
    echo "🤖 Running: lab start meshintro-bookinfo"
    
    echo "SUCCESS Copying lab files to workspace"
    echo "SUCCESS Making traffic_gen.py executable and adding to PATH"
    echo "SUCCESS Verifying cluster state"
    
    # 2. 개별 사용자용 네임스페이스 기동 및 이동
    echo "📂 Creating/switching to the meshintro-bookinfo project..."
    oc new-project "$NAMESPACE" 2>/dev/null || oc project "$NAMESPACE"
    
    # 3. 진짜 북인포 실습 템플릿 자산 배포
    MANIFESTS_DIR="/opt/app-root/src/labs/meshintro-bookinfo/manifests"
    if [ ! -d "$MANIFESTS_DIR" ]; then
        MANIFESTS_DIR="$(dirname "$0")/../labs/meshintro-bookinfo/manifests"
    fi
    
    if [ ! -d "$MANIFESTS_DIR" ]; then
        echo "❌ Error: 실습 리소스 디렉토리를 찾을 수 없습니다 ($MANIFESTS_DIR)"
        exit 1
    fi
    
    echo "🏗️  Installing the Bookinfo Application..."
    oc apply -f "$MANIFESTS_DIR/bookinfo.yaml" -n "$NAMESPACE"
    oc apply -f "$MANIFESTS_DIR/bookinfo-gateway.yaml" -n "$NAMESPACE"
    oc apply -f "$MANIFESTS_DIR/traffic-generator-configmap.yaml" -n "$NAMESPACE"
    
    # 트래픽 제너레이터의 대상을 해당 유저 전용 인그레스 게이트웨이 주소로 동적 패치!
    INGRESS_HOST=$(oc get route istio-ingressgateway -n "${USER_NAME}-istio-ingress" -o jsonpath='{.spec.host}' 2>/dev/null || true)
    if [ -n "$INGRESS_HOST" ]; then
        echo "🔧 Patching traffic generator config to use dynamic route http://${INGRESS_HOST}/productpage..."
        oc patch configmap traffic-generator-config -n "$NAMESPACE" --type=merge -p "{\"data\":{\"route\":\"http://${INGRESS_HOST}/productpage\"}}" 2>/dev/null || true
    fi
    
    oc apply -f "$MANIFESTS_DIR/traffic-generator.yaml" -n "$NAMESPACE"
    
    echo "🧪 Installing curl pod..."
    oc apply -f "$MANIFESTS_DIR/curl.yaml" -n "$NAMESPACE"
    
    # 4. 주요 디플로이먼트 가동 및 READY 상태 도달할 때까지 실시간 대기 추적
    echo "⏱️  배포 중인 마이크로서비스들의 기동을 확인합니다 (약 수십 초 대기)..."
    oc rollout status deployment/productpage-v1 -n "$NAMESPACE" --timeout=60s || true
    oc rollout status deployment/details-v1 -n "$NAMESPACE" --timeout=60s || true
    oc rollout status deployment/reviews-v1 -n "$NAMESPACE" --timeout=60s || true
    oc rollout status deployment/reviews-v2 -n "$NAMESPACE" --timeout=60s || true
    oc rollout status deployment/reviews-v3 -n "$NAMESPACE" --timeout=60s || true
    oc rollout status deployment/ratings-v1 -n "$NAMESPACE" --timeout=60s || true
    oc rollout status deployment/curl -n "$NAMESPACE" --timeout=60s || true
    
    echo "SUCCESS Installing the Bookinfo Application"
    echo "SUCCESS Installing curl pod"
    echo "🎉 Lab meshintro-bookinfo successfully started!"
    
elif [ "$COMMAND" = "finish" ]; then
    echo "🧹 Completing and cleaning up lab '$LAB_NAME'..."
    
    if oc get project "$NAMESPACE" &>/dev/null; then
        echo "📂 Deleting project '$NAMESPACE'..."
        oc delete project "$NAMESPACE"
    fi
    
    echo "SUCCESS Deleting project '$NAMESPACE'"
    echo "🎉 Lab meshintro-bookinfo successfully completed and cleaned!"
    
else
    echo "❌ Unknown command: $COMMAND. Supported commands: start, finish"
    exit 1
fi
